{
  "name": "@donezone/template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.1",
  "workspaces": [
    "contracts/*",
    "frontend"
  ],
  "scripts": {
    "dev": "bun run --cwd frontend dev",
    "build": "bun run --cwd frontend build",
    "local": "bun run  bun run --cwd frontend dev",
    "preview": "bunx @donezone/cli dev & bun run--cwd frontend preview",
    "contracts:build": "bunx @donezone/cli build",
    "contracts:deploy": "bunx @donezone/cli deploy",
    "contracts:dev": "bunx @donezone/cli dev"
  },
  "devDependencies": {
    "@donezone/cli": "^0.1.0",
    "@donezone/contract-types": "^0.1.0",
    "@types/bun": "^1.1.10",
    "typescript": "^5.8.3"
  }
}